# Database
# PostgreSQL connection string (Neon, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# NextAuth
# Generate with: openssl rand -base64 32 or `npx auth secret`
NEXTAUTH_SECRET=your-super-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# App
NODE_ENV=development

# ⚠️ IMPORTANT SECURITY NOTES
# 1. NEVER commit this file or your actual .env to git
# 2. Rotate NEXTAUTH_SECRET regularly in production
# 3. Use a strong, unique NEXTAUTH_SECRET (at least 32 chars)
# 4. In production, always use HTTPS for NEXTAUTH_URL
# 5. Never expose DATABASE_URL in client-side code
# 6. Use database connection pooling for production deployments
